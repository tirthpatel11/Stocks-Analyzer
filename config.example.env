# Use ONE provider: Groq OR xAI Grok (not both required).

# --- Groq (Llama, etc.) — set GROQ_API_KEY and leave GROK_API_KEY empty unless you use xAI ---
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- xAI Grok — set GROK_API_KEY and leave GROQ_API_KEY empty unless you use Groq ---
GROK_API_KEY=
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-3-mini

# Application Settings
DEBUG=true
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
